{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "rawafed-admission-management": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "raw",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/rawafed-admission-management",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {"glob": "**/*", "input": "public"},
              {"glob": "**/*", "input": "src/assets", "output": "assets"}
            ],
            "styles": ["src/styles.scss"],
            "scripts": [],
            "allowedCommonJsDependencies": [
              "qrcode",
              "html2canvas",
              "dompurify",
              "canvg",
              "core-js",
              "raf",
              "rgbcolor"
            ],
            "serviceWorker": "ngsw-config.json"
          },
          "configurations": {
            "production": {
              "budgets": [
                {"type": "initial", "maximumWarning": "1.4MB", "maximumError": "1.8MB"},
                {"type": "anyComponentStyle", "maximumWarning": "12kB", "maximumError": "24kB"}
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "serviceWorker": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {"buildTarget": "rawafed-admission-management:build:production"},
            "development": {"buildTarget": "rawafed-admission-management:build:development"}
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {"analytics": false}
}
