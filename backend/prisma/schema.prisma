generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentStatus {
  PENDING
  COMPLETED
  VOID
  REFUNDED
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  username        String           @unique
  email           String?          @unique
  passwordHash    String           @map("password_hash")
  displayName     String           @map("display_name")
  employeeCode    String?          @unique @map("employee_code")
  phone           String?
  department      String?
  jobTitle        String?          @map("job_title")
  roleId          String           @map("role_id") @db.Uuid
  role            Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  active          Boolean          @default(true)
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  createdJournals JournalEntry[]   @relation("JournalCreator")
  payrollRuns     PayrollRun[]     @relation("PayrollCreator")
  reportTemplates ReportTemplate[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  @@index([roleId, active])
  @@index([department, active])
  @@index([deletedAt])
  @@map("users")
}

model ReportTemplate {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  reportType String   @map("report_type")
  filters    Json     @default("{}")
  columns    Json     @default("[]")
  groupBy    String?  @map("group_by")
  sortBy     String?  @map("sort_by")
  chartType  String?  @map("chart_type")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, name])
  @@index([userId, reportType])
  @@map("report_templates")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("refresh_tokens")
}

model Branch {
  id                 String               @id @default(uuid()) @db.Uuid
  code               String               @unique
  name               String
  nameAr             String?              @map("name_ar")
  active             Boolean              @default(true)
  registrations      Registration[]
  students           Student[]
  staff              Staff[]
  fiscalYears        AcademicYear[]
  journalEntries     JournalEntry[]
  fixedAssets        FixedAsset[]
  assetTransfersFrom FixedAssetTransfer[] @relation("AssetTransferFromBranch")
  assetTransfersTo   FixedAssetTransfer[] @relation("AssetTransferToBranch")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")

  @@index([active, deletedAt])
  @@map("branches")
}

model AcademicYear {
  id             String         @id @default(uuid()) @db.Uuid
  branchId       String         @map("branch_id") @db.Uuid
  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name           String
  startsAt       DateTime       @map("starts_at") @db.Date
  endsAt         DateTime       @map("ends_at") @db.Date
  active         Boolean        @default(false)
  registrations  Registration[]
  journalEntries JournalEntry[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  @@unique([branchId, name])
  @@index([branchId, active])
  @@map("academic_years")
}

model Registration {
  id                 String              @id @default(uuid()) @db.Uuid
  registrationNumber String              @unique @map("registration_number")
  branchId           String              @map("branch_id") @db.Uuid
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  academicYearId     String?             @map("academic_year_id") @db.Uuid
  academicYear       AcademicYear?       @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  status             String
  studentName        String?             @map("student_name")
  grade              String?
  submittedAt        DateTime?           @map("submitted_at")
  data               Json
  student            Student?
  financeAccount     FinanceAccount?
  invoices           FinanceInvoice[]
  payments           FinancePayment[]
  customer           AccountingCustomer?
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  @@index([branchId, status])
  @@index([academicYearId, status])
  @@index([submittedAt])
  @@map("registrations")
}

model Student {
  id                 String              @id @default(uuid()) @db.Uuid
  registrationId     String?             @unique @map("registration_id") @db.Uuid
  registration       Registration?       @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  branchId           String              @map("branch_id") @db.Uuid
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  registrationNumber String?             @map("registration_number")
  englishName        String              @map("english_name")
  arabicName         String?             @map("arabic_name")
  grade              String
  nationalId         String?             @unique @map("national_id")
  passportNumber     String?             @unique @map("passport_number")
  parentName         String?             @map("parent_name")
  parentPhone        String?             @map("parent_phone")
  parentEmail        String?             @map("parent_email")
  status             String              @default("active")
  profile            Json                @default("{}")
  financeAccount     FinanceAccount?
  customer           AccountingCustomer?
  inventoryMovements StockMovement[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  @@index([branchId, grade, status])
  @@index([registrationNumber])
  @@map("students")
}

model FinanceAccount {
  id             String                  @id @default(uuid()) @db.Uuid
  registrationId String                  @unique @map("registration_id") @db.Uuid
  registration   Registration            @relation(fields: [registrationId], references: [id], onDelete: Restrict)
  studentId      String                  @unique @map("student_id") @db.Uuid
  student        Student                 @relation(fields: [studentId], references: [id], onDelete: Restrict)
  currency       String                  @default("SAR") @db.Char(3)
  expectedTotal  Decimal                 @default(0) @map("expected_total") @db.Decimal(14, 2)
  invoices       FinanceInvoice[]
  payments       FinancePayment[]
  feeItems       FinanceAccountFeeItem[]
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  deletedAt      DateTime?               @map("deleted_at")

  @@index([deletedAt])
  @@map("finance_accounts")
}

model FinanceAccountFeeItem {
  id                 String                 @id @default(uuid()) @db.Uuid
  accountId          String                 @map("account_id") @db.Uuid
  account            FinanceAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name               String
  amount             Decimal                @db.Decimal(14, 2)
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  paymentAllocations PaymentFeeAllocation[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("finance_account_fee_items")
}

model FinanceInvoice {
  id             String              @id @default(uuid()) @db.Uuid
  invoiceNumber  String              @unique @map("invoice_number")
  accountId      String              @map("account_id") @db.Uuid
  account        FinanceAccount      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  registrationId String?             @map("registration_id") @db.Uuid
  registration   Registration?       @relation(fields: [registrationId], references: [id], onDelete: Restrict)
  subtotal       Decimal             @db.Decimal(14, 2)
  vatAmount      Decimal             @default(0) @map("vat_amount") @db.Decimal(14, 2)
  total          Decimal             @db.Decimal(14, 2)
  status         InvoiceStatus       @default(ISSUED)
  issuedAt       DateTime            @map("issued_at")
  dueAt          DateTime?           @map("due_at")
  lines          InvoiceLine[]
  payments       PaymentAllocation[]
  journalEntries JournalEntry[]
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")

  @@index([accountId, status])
  @@index([issuedAt])
  @@map("finance_invoices")
}

model InvoiceLine {
  id               String          @id @default(uuid()) @db.Uuid
  invoiceId        String          @map("invoice_id") @db.Uuid
  invoice          FinanceInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description      String
  quantity         Decimal         @default(1) @db.Decimal(12, 3)
  unitPrice        Decimal         @map("unit_price") @db.Decimal(14, 2)
  vatRate          Decimal         @default(0) @map("vat_rate") @db.Decimal(5, 2)
  netAmount        Decimal         @map("net_amount") @db.Decimal(14, 2)
  vatAmount        Decimal         @map("vat_amount") @db.Decimal(14, 2)
  totalAmount      Decimal         @map("total_amount") @db.Decimal(14, 2)
  revenueAccountId String?         @map("revenue_account_id") @db.Uuid
  revenueAccount   ChartOfAccount? @relation(fields: [revenueAccountId], references: [id], onDelete: Restrict)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([invoiceId])
  @@map("invoice_lines")
}

model FinancePayment {
  id              String                 @id @default(uuid()) @db.Uuid
  receiptNumber   String                 @unique @map("receipt_number")
  accountId       String                 @map("account_id") @db.Uuid
  account         FinanceAccount         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  registrationId  String?                @map("registration_id") @db.Uuid
  registration    Registration?          @relation(fields: [registrationId], references: [id], onDelete: Restrict)
  amount          Decimal                @db.Decimal(14, 2)
  method          String
  status          PaymentStatus          @default(COMPLETED)
  referenceNumber String?                @map("reference_number")
  notes           String?
  paidAt          DateTime               @map("paid_at")
  collectedBy     String?                @map("collected_by")
  allocations     PaymentAllocation[]
  feeAllocations  PaymentFeeAllocation[]
  journalEntries  JournalEntry[]
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  deletedAt       DateTime?              @map("deleted_at")

  @@index([accountId, paidAt])
  @@index([status, paidAt])
  @@map("finance_payments")
}

model PaymentFeeAllocation {
  id        String                @id @default(uuid()) @db.Uuid
  paymentId String                @map("payment_id") @db.Uuid
  payment   FinancePayment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  feeItemId String                @map("fee_item_id") @db.Uuid
  feeItem   FinanceAccountFeeItem @relation(fields: [feeItemId], references: [id], onDelete: Restrict)
  amount    Decimal               @db.Decimal(14, 2)
  createdAt DateTime              @default(now()) @map("created_at")

  @@unique([paymentId, feeItemId])
  @@index([feeItemId])
  @@map("payment_fee_allocations")
}

model PaymentAllocation {
  id        String         @id @default(uuid()) @db.Uuid
  paymentId String         @map("payment_id") @db.Uuid
  payment   FinancePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId String         @map("invoice_id") @db.Uuid
  invoice   FinanceInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount    Decimal        @db.Decimal(14, 2)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
  @@map("payment_allocations")
}

model FinanceExpense {
  id               String          @id @default(uuid()) @db.Uuid
  category         String
  title            String
  amount           Decimal         @db.Decimal(14, 2)
  vatAmount        Decimal         @default(0) @map("vat_amount") @db.Decimal(14, 2)
  date             DateTime        @db.Date
  status           String
  notes            String?
  expenseAccountId String?         @map("expense_account_id") @db.Uuid
  expenseAccount   ChartOfAccount? @relation(fields: [expenseAccountId], references: [id], onDelete: Restrict)
  journalEntries   JournalEntry[]
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  @@index([date, status])
  @@map("finance_expenses")
}

model ChartOfAccount {
  id                          String               @id @default(uuid()) @db.Uuid
  code                        String               @unique
  name                        String
  nameAr                      String?              @map("name_ar")
  type                        AccountType
  parentId                    String?              @map("parent_id") @db.Uuid
  parent                      ChartOfAccount?      @relation("AccountTree", fields: [parentId], references: [id], onDelete: Restrict)
  children                    ChartOfAccount[]     @relation("AccountTree")
  active                      Boolean              @default(true)
  system                      Boolean              @default(false)
  systemKey                   String?              @unique @map("system_key")
  currency                    String               @default("SAR") @db.Char(3)
  openingBalance              Decimal              @default(0) @map("opening_balance") @db.Decimal(14, 2)
  openingDate                 DateTime?            @map("opening_date") @db.Date
  notes                       String?
  normalBalance               String               @default("DEBIT") @map("normal_balance")
  allowPosting                Boolean              @default(true) @map("allow_posting")
  allowManualJournal          Boolean              @default(true) @map("allow_manual_journal")
  isCashAccount               Boolean              @default(false) @map("is_cash_account")
  isBankAccount               Boolean              @default(false) @map("is_bank_account")
  isVatAccount                Boolean              @default(false) @map("is_vat_account")
  isReceivableAccount         Boolean              @default(false) @map("is_receivable_account")
  isPayableAccount            Boolean              @default(false) @map("is_payable_account")
  costCenterId                String?              @map("cost_center_id") @db.Uuid
  costCenter                  CostCenter?          @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  journalLines                JournalLine[]
  invoiceLines                InvoiceLine[]
  expenses                    FinanceExpense[]
  cashbox                     Cashbox?
  bank                        Bank?
  receivableCustomers         AccountingCustomer[]
  payableSuppliers            AccountingSupplier[]
  accountingExpenses          AccountingExpense[]  @relation("ExpenseAccount")
  paidExpenses                AccountingExpense[]  @relation("ExpensePaymentAccount")
  supplierPayments            SupplierPayment[]
  customerPayments            CustomerPayment[]
  assetCategories             FixedAssetCategory[] @relation("AssetCategoryAssetAccount")
  accumulatedAssetCategories  FixedAssetCategory[] @relation("AssetCategoryAccumulatedAccount")
  depreciationAssetCategories FixedAssetCategory[] @relation("AssetCategoryExpenseAccount")
  createdAt                   DateTime             @default(now()) @map("created_at")
  updatedAt                   DateTime             @updatedAt @map("updated_at")
  deletedAt                   DateTime?            @map("deleted_at")

  @@index([parentId])
  @@index([type, active])
  @@index([costCenterId])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id                String                  @id @default(uuid()) @db.Uuid
  entryNumber       String                  @unique @map("entry_number")
  branchId          String                  @map("branch_id") @db.Uuid
  branch            Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  academicYearId    String?                 @map("academic_year_id") @db.Uuid
  academicYear      AcademicYear?           @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  postingDate       DateTime                @map("posting_date") @db.Date
  description       String
  status            JournalStatus           @default(POSTED)
  sourceType        String?                 @map("source_type")
  sourceId          String?                 @map("source_id")
  referenceNumber   String?                 @map("reference_number")
  createdById       String?                 @map("created_by_id") @db.Uuid
  createdBy         User?                   @relation("JournalCreator", fields: [createdById], references: [id], onDelete: SetNull)
  postedAt          DateTime?               @map("posted_at")
  reversedFromId    String?                 @unique @map("reversed_from_id") @db.Uuid
  reversedFrom      JournalEntry?           @relation("JournalReversal", fields: [reversedFromId], references: [id], onDelete: Restrict)
  reversal          JournalEntry?           @relation("JournalReversal")
  invoiceId         String?                 @map("invoice_id") @db.Uuid
  invoice           FinanceInvoice?         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  paymentId         String?                 @map("payment_id") @db.Uuid
  payment           FinancePayment?         @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  expenseId         String?                 @map("expense_id") @db.Uuid
  expense           FinanceExpense?         @relation(fields: [expenseId], references: [id], onDelete: Restrict)
  accountingExpense AccountingExpense?
  supplierPayment   SupplierPayment?
  customerPayment   CustomerPayment?
  transfer          CashBankTransfer?
  payrollRun        PayrollRun?
  acquiredAsset     FixedAsset?
  assetDepreciation FixedAssetDepreciation?
  assetDisposal     FixedAssetDisposal?
  lines             JournalLine[]
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  deletedAt         DateTime?               @map("deleted_at")

  @@unique([sourceType, sourceId])
  @@index([branchId, postingDate, status])
  @@map("journal_entries")
}

model JournalLine {
  id             String         @id @default(uuid()) @db.Uuid
  journalEntryId String         @map("journal_entry_id") @db.Uuid
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String         @map("account_id") @db.Uuid
  account        ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  description    String?
  costCenterId   String?        @map("cost_center_id") @db.Uuid
  costCenter     CostCenter?    @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  currency       String         @default("SAR") @db.Char(3)
  debit          Decimal        @default(0) @db.Decimal(14, 2)
  credit         Decimal        @default(0) @db.Decimal(14, 2)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([journalEntryId])
  @@index([accountId])
  @@index([costCenterId])
  @@map("journal_lines")
}

model CostCenter {
  id           String              @id @default(uuid()) @db.Uuid
  code         String              @unique
  nameAr       String              @map("name_ar")
  nameEn       String              @map("name_en")
  active       Boolean             @default(true)
  accounts     ChartOfAccount[]
  journalLines JournalLine[]
  expenses     AccountingExpense[]
  fixedAssets  FixedAsset[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  deletedAt    DateTime?           @map("deleted_at")

  @@index([active, deletedAt])
  @@map("cost_centers")
}

model AccountingCustomer {
  id                  String            @id @default(uuid()) @db.Uuid
  customerCode        String            @unique @map("customer_code")
  studentId           String?           @unique @map("student_id") @db.Uuid
  student             Student?          @relation(fields: [studentId], references: [id], onDelete: SetNull)
  registrationId      String?           @unique @map("registration_id") @db.Uuid
  registration        Registration?     @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  registrationNumber  String?           @map("registration_number")
  parentLink          String?           @map("parent_link")
  nameAr              String?           @map("name_ar")
  nameEn              String            @map("name_en")
  phone               String?
  email               String?
  nationalId          String?           @map("national_id")
  openingBalance      Decimal           @default(0) @map("opening_balance") @db.Decimal(14, 2)
  creditLimit         Decimal           @default(0) @map("credit_limit") @db.Decimal(14, 2)
  receivableAccountId String            @map("receivable_account_id") @db.Uuid
  receivableAccount   ChartOfAccount    @relation(fields: [receivableAccountId], references: [id], onDelete: Restrict)
  active              Boolean           @default(true)
  notes               String?
  installmentPlans    InstallmentPlan[]
  installments        Installment[]
  payments            CustomerPayment[]
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  deletedAt           DateTime?         @map("deleted_at")

  @@index([registrationNumber])
  @@index([receivableAccountId, active])
  @@map("accounting_customers")
}

model AccountingSupplier {
  id                     String              @id @default(uuid()) @db.Uuid
  supplierCode           String              @unique @map("supplier_code")
  nameAr                 String?             @map("name_ar")
  nameEn                 String              @map("name_en")
  vatNumber              String?             @map("vat_number")
  commercialRegistration String?             @map("commercial_registration")
  phone                  String?
  email                  String?
  address                String?
  city                   String?
  contactPerson          String?             @map("contact_person")
  paymentTerms           String?             @map("payment_terms")
  openingBalance         Decimal             @default(0) @map("opening_balance") @db.Decimal(14, 2)
  payableAccountId       String              @map("payable_account_id") @db.Uuid
  payableAccount         ChartOfAccount      @relation(fields: [payableAccountId], references: [id], onDelete: Restrict)
  active                 Boolean             @default(true)
  notes                  String?
  expenses               AccountingExpense[]
  payments               SupplierPayment[]
  purchaseOrders         PurchaseOrder[]
  goodsReceipts          GoodsReceipt[]
  inventoryItems         InventoryItem[]
  fixedAssets            FixedAsset[]
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  deletedAt              DateTime?           @map("deleted_at")

  @@index([payableAccountId, active])
  @@map("accounting_suppliers")
}

model Cashbox {
  id        String         @id @default(uuid()) @db.Uuid
  accountId String         @unique @map("account_id") @db.Uuid
  account   ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  name      String
  active    Boolean        @default(true)
  notes     String?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")

  @@index([active, deletedAt])
  @@map("cashboxes")
}

model Bank {
  id            String         @id @default(uuid()) @db.Uuid
  accountId     String         @unique @map("account_id") @db.Uuid
  account       ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  bankName      String         @map("bank_name")
  iban          String?
  accountNumber String?        @map("account_number")
  active        Boolean        @default(true)
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  @@index([active, deletedAt])
  @@map("banks")
}

model AccountingExpense {
  id                    String              @id @default(uuid()) @db.Uuid
  expenseNo             String              @unique @map("expense_no")
  supplierId            String?             @map("supplier_id") @db.Uuid
  supplier              AccountingSupplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  expenseAccountId      String              @map("expense_account_id") @db.Uuid
  expenseAccount        ChartOfAccount      @relation("ExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: Restrict)
  invoiceType           String              @map("invoice_type")
  supplierInvoiceNumber String?             @map("supplier_invoice_number")
  description           String
  costCenterId          String?             @map("cost_center_id") @db.Uuid
