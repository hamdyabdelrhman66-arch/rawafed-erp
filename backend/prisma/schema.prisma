  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([countId, itemId])
  @@map("inventory_count_lines")
}

model InventorySetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("inventory_settings")
}

model InventoryAccountingEvent {
  id            String    @id @default(uuid()) @db.Uuid
  eventType     String    @map("event_type")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  referenceNo   String?   @map("reference_no")
  eventDate     DateTime  @map("event_date")
  amount        Decimal   @default(0) @db.Decimal(14, 2)
  status        String    @default("PENDING")
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([eventType, aggregateId])
  @@index([status, createdAt])
  @@map("inventory_accounting_events")
}

model VatRate {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  name      String
  rate      Decimal   @db.Decimal(5, 2)
  active    Boolean   @default(true)
  validFrom DateTime  @map("valid_from") @db.Date
  validTo   DateTime? @map("valid_to") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([active, validFrom, validTo])
  @@map("vat_rates")
}

model FixedAssetCategory {
  id                               String         @id @default(uuid()) @db.Uuid
  code                             String         @unique
  nameAr                           String         @map("name_ar")
  nameEn                           String         @map("name_en")
  usefulLifeMonths                 Int            @default(60) @map("useful_life_months")
  depreciationMethod               String         @default("STRAIGHT_LINE") @map("depreciation_method")
  decliningRate                    Decimal?       @map("declining_rate") @db.Decimal(7, 4)
  assetAccountId                   String         @map("asset_account_id") @db.Uuid
  assetAccount                     ChartOfAccount @relation("AssetCategoryAssetAccount", fields: [assetAccountId], references: [id], onDelete: Restrict)
  accumulatedDepreciationAccountId String         @map("accumulated_depreciation_account_id") @db.Uuid
  accumulatedDepreciationAccount   ChartOfAccount @relation("AssetCategoryAccumulatedAccount", fields: [accumulatedDepreciationAccountId], references: [id], onDelete: Restrict)
  depreciationExpenseAccountId     String         @map("depreciation_expense_account_id") @db.Uuid
  depreciationExpenseAccount       ChartOfAccount @relation("AssetCategoryExpenseAccount", fields: [depreciationExpenseAccountId], references: [id], onDelete: Restrict)
  active                           Boolean        @default(true)
  notes                            String?
  assets                           FixedAsset[]
  createdAt                        DateTime       @default(now()) @map("created_at")
  updatedAt                        DateTime       @updatedAt @map("updated_at")
  deletedAt                        DateTime?      @map("deleted_at")

  @@index([active, deletedAt])
  @@map("fixed_asset_categories")
}

model FixedAsset {
  id                   String                   @id @default(uuid()) @db.Uuid
  assetCode            String                   @unique @map("asset_code")
  nameAr               String                   @map("name_ar")
  nameEn               String                   @map("name_en")
  categoryId           String                   @map("category_id") @db.Uuid
  category             FixedAssetCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  branchId             String                   @map("branch_id") @db.Uuid
  branch               Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  costCenterId         String?                  @map("cost_center_id") @db.Uuid
  costCenter           CostCenter?              @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  supplierId           String?                  @map("supplier_id") @db.Uuid
  supplier             AccountingSupplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseDate         DateTime                 @map("purchase_date") @db.Date
  purchaseInvoice      String?                  @map("purchase_invoice")
  purchaseCost         Decimal                  @map("purchase_cost") @db.Decimal(14, 2)
  residualValue        Decimal                  @default(0) @map("residual_value") @db.Decimal(14, 2)
  usefulLifeMonths     Int                      @map("useful_life_months")
  depreciationMethod   String                   @map("depreciation_method")
  decliningRate        Decimal?                 @map("declining_rate") @db.Decimal(7, 4)
  currentBookValue     Decimal                  @map("current_book_value") @db.Decimal(14, 2)
  status               String                   @default("ACTIVE")
  custodian            String?
  location             String?
  barcode              String?                  @unique
  warrantyEndsAt       DateTime?                @map("warranty_ends_at") @db.Date
  notes                String?
  attachments          Json                     @default("[]")
  acquisitionJournalId String?                  @unique @map("acquisition_journal_id") @db.Uuid
  acquisitionJournal   JournalEntry?            @relation(fields: [acquisitionJournalId], references: [id], onDelete: Restrict)
  depreciationEntries  FixedAssetDepreciation[]
  transfers            FixedAssetTransfer[]
  disposals            FixedAssetDisposal[]
  maintenance          FixedAssetMaintenance[]
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  deletedAt            DateTime?                @map("deleted_at")

  @@index([categoryId, status])
  @@index([branchId, status])
  @@index([costCenterId])
  @@map("fixed_assets")
}

model FixedAssetDepreciation {
  id                String       @id @default(uuid()) @db.Uuid
  assetId           String       @map("asset_id") @db.Uuid
  asset             FixedAsset   @relation(fields: [assetId], references: [id], onDelete: Restrict)
  period            DateTime     @db.Date
  amount            Decimal      @db.Decimal(14, 2)
  accumulatedAmount Decimal      @map("accumulated_amount") @db.Decimal(14, 2)
  bookValueAfter    Decimal      @map("book_value_after") @db.Decimal(14, 2)
  journalEntryId    String       @unique @map("journal_entry_id") @db.Uuid
  journalEntry      JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@unique([assetId, period])
  @@index([period])
  @@map("fixed_asset_depreciation")
}

model FixedAssetTransfer {
  id            String     @id @default(uuid()) @db.Uuid
  assetId       String     @map("asset_id") @db.Uuid
  asset         FixedAsset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  transferDate  DateTime   @map("transfer_date") @db.Date
  fromBranchId  String     @map("from_branch_id") @db.Uuid
  fromBranch    Branch     @relation("AssetTransferFromBranch", fields: [fromBranchId], references: [id], onDelete: Restrict)
  toBranchId    String     @map("to_branch_id") @db.Uuid
  toBranch      Branch     @relation("AssetTransferToBranch", fields: [toBranchId], references: [id], onDelete: Restrict)
  fromLocation  String?    @map("from_location")
  toLocation    String?    @map("to_location")
  fromCustodian String?    @map("from_custodian")
  toCustodian   String?    @map("to_custodian")
  notes         String?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([assetId, transferDate])
  @@map("fixed_asset_transfers")
}

model FixedAssetDisposal {
  id             String       @id @default(uuid()) @db.Uuid
  assetId        String       @map("asset_id") @db.Uuid
  asset          FixedAsset   @relation(fields: [assetId], references: [id], onDelete: Restrict)
  disposalDate   DateTime     @map("disposal_date") @db.Date
  disposalType   String       @map("disposal_type")
  proceeds       Decimal      @default(0) @db.Decimal(14, 2)
  bookValue      Decimal      @map("book_value") @db.Decimal(14, 2)
  gainLoss       Decimal      @map("gain_loss") @db.Decimal(14, 2)
  reason         String?
  buyer          String?
  journalEntryId String       @unique @map("journal_entry_id") @db.Uuid
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([assetId, disposalDate])
  @@map("fixed_asset_disposals")
}

model FixedAssetMaintenance {
  id              String     @id @default(uuid()) @db.Uuid
  assetId         String     @map("asset_id") @db.Uuid
  asset           FixedAsset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  maintenanceDate DateTime   @map("maintenance_date") @db.Date
  maintenanceType String     @map("maintenance_type")
  supplierName    String?    @map("supplier_name")
  cost            Decimal    @default(0) @db.Decimal(14, 2)
  nextDueDate     DateTime?  @map("next_due_date") @db.Date
  status          String     @default("COMPLETED")
  description     String
  notes           String?
  attachments     Json       @default("[]")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([assetId, maintenanceDate])
  @@index([nextDueDate])
  @@map("fixed_asset_maintenance")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  message     String
  targetRoles Json      @map("target_roles")
  category    String
  readBy      Json      @default("[]") @map("read_by")
  link        String?
  sourceId    String?   @map("source_id")
  sourceType  String?   @map("source_type")
  eventType   String?   @map("event_type")
  targetRole  String?   @map("target_role")
  messageKey  String?   @map("message_key")
  parameters  Json?     @map("parameters")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@unique([sourceType, sourceId, eventType, targetRole])
  @@index([category, createdAt])
  @@index([sourceId])
  @@map("notifications")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  actorId        String?  @map("actor_id") @db.Uuid
  actor          User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorRole      String?  @map("actor_role")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  details        Json?
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model AccountingOutbox {
  id            String    @id @default(uuid()) @db.Uuid
  eventType     String    @map("event_type")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  payload       Json
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([eventType, aggregateId])
  @@index([processedAt, createdAt])
  @@map("accounting_outbox")
}

model Staff {
  id           String        @id @default(uuid()) @db.Uuid
  branchId     String        @map("branch_id") @db.Uuid
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  name         String
  position     String
  department   String
  phone        String?
  email        String?
  salary       Decimal       @default(0) @db.Decimal(14, 2)
  startDate    DateTime?     @map("start_date") @db.Date
  nationality  String?
  idNumber     String?       @unique @map("id_number")
  status       String
  notes        String?
  profile      Json          @default("{}")
  payrollLines PayrollLine[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  @@index([branchId, department, status])
  @@map("staff")
}

model PayrollRun {
  id                String        @id @default(uuid()) @db.Uuid
  period            String
  paymentDate       DateTime      @map("payment_date") @db.Date
  status            String        @default("Posted")
  grossTotal        Decimal       @map("gross_total") @db.Decimal(14, 2)
  deductionsTotal   Decimal       @map("deductions_total") @db.Decimal(14, 2)
  employerGosiTotal Decimal       @map("employer_gosi_total") @db.Decimal(14, 2)
  netTotal          Decimal       @map("net_total") @db.Decimal(14, 2)
  journalEntryId    String        @unique @map("journal_entry_id") @db.Uuid
  journalEntry      JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdById       String?       @map("created_by_id") @db.Uuid
  createdBy         User?         @relation("PayrollCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines             PayrollLine[]
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  @@unique([period, status])
  @@index([paymentDate, status])
  @@map("payroll_runs")
}

model PayrollLine {
  id                      String     @id @default(uuid()) @db.Uuid
  payrollRunId            String     @map("payroll_run_id") @db.Uuid
  payrollRun              PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId              String     @map("employee_id") @db.Uuid
  employee                Staff      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  employeeName            String     @map("employee_name")
  basicSalary             Decimal    @map("basic_salary") @db.Decimal(14, 2)
  housingAllowance        Decimal    @default(0) @map("housing_allowance") @db.Decimal(14, 2)
  transportationAllowance Decimal    @default(0) @map("transportation_allowance") @db.Decimal(14, 2)
  otherAllowances         Decimal    @default(0) @map("other_allowances") @db.Decimal(14, 2)
  overtime                Decimal    @default(0) @db.Decimal(14, 2)
  bonus                   Decimal    @default(0) @db.Decimal(14, 2)
  absenceDeduction        Decimal    @default(0) @map("absence_deduction") @db.Decimal(14, 2)
  lateDeduction           Decimal    @default(0) @map("late_deduction") @db.Decimal(14, 2)
  loanDeduction           Decimal    @default(0) @map("loan_deduction") @db.Decimal(14, 2)
  advanceDeduction        Decimal    @default(0) @map("advance_deduction") @db.Decimal(14, 2)
  gosiEmployee            Decimal    @default(0) @map("gosi_employee") @db.Decimal(14, 2)
  gosiEmployer            Decimal    @default(0) @map("gosi_employer") @db.Decimal(14, 2)
  otherDeductions         Decimal    @default(0) @map("other_deductions") @db.Decimal(14, 2)
  gross                   Decimal    @db.Decimal(14, 2)
  deductions              Decimal    @db.Decimal(14, 2)
  net                     Decimal    @db.Decimal(14, 2)
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@map("payroll_lines")
}

model UploadedFile {
  id           String    @id @default(uuid()) @db.Uuid
  originalName String    @map("original_name")
  fileName     String    @unique @map("file_name")
  mimeType     String    @map("mime_type")
  size         Int
  url          String
  label        String?
  ownerId      String?   @map("owner_id")
  uploadedBy   String?   @map("uploaded_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([ownerId])
  @@map("uploaded_files")
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
