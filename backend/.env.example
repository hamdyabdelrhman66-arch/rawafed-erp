PORT=4300
PERSISTENCE_DRIVER=postgres
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Optional explicit pooled runtime URL. If omitted for Neon, the backend derives the documented -pooler endpoint automatically.
DATABASE_POOL_URL=
DATABASE_USE_NEON_POOLER=true
DATABASE_CONNECTION_LIMIT=3
DATABASE_POOL_TIMEOUT=20
DATABASE_CONNECT_TIMEOUT=15
TEST_DATABASE_URL=postgresql://test-user:test-password@test-host/test-database?sslmode=require
JWT_SECRET=replace-with-at-least-32-random-characters
REFRESH_SECRET=replace-with-a-different-32-character-secret
CORS_ORIGIN=http://127.0.0.1:4200,http://localhost:4200
LOG_LEVEL=info
BUILD_VERSION=local
GIT_COMMIT=unknown
BACKUP_DIR=./backups/postgresql
BACKUP_RETENTION_DAYS=30
